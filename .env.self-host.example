# =============================================================================
# Midplane self-host (single-tenant). Copy to .env.self-host and fill secrets.
# =============================================================================
# Keyless, uncapped, single-owner, ONE Postgres, no region routing, no cloud
# vendors. See SELF_HOST.md for the run. The full env surface is enumerated in
# the SELFHOST block of .env.example.
#
# `./bin/self-host up` creates this file from the example and fills the three
# generated secrets below for you — you only edit it by hand for the from-source
# path or to change a default (e.g. POSTGRES_PORT).

# Selects the single-tenant build. Without this, the app expects the multi-
# tenant cloud config (per-region DBs, region cookie, Fly) and won't boot here.
MIDPLANE_SELF_HOST=1

# The single Postgres (replaces DATABASE_URL_EU / DATABASE_URL_US).
#
# This value is for the FROM-SOURCE path (running `bun run dev` on the host): the
# bundled compose maps Postgres to localhost:${POSTGRES_PORT:-5432}. In the
# containerized compose stack the web service IGNORES this and talks to the
# in-network `postgres` service directly — so you don't edit it for `bin/self-host up`.
DATABASE_URL=postgres://midplane:midplane@localhost:5432/midplane?sslmode=disable

# Session signing.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of this app. Drives cookie domain + callback URLs.
BETTER_AUTH_URL=http://localhost:3000

# Credential encryption at rest — env-mode local AES (no AWS in self-host). The
# _EU suffix is an internal artifact of the fixed region pin (SELF_HOST_REGION);
# these are local key material, not a regional choice.
#
# DO NOT rotate these once data exists: MIDPLANE_KMS_DEV_KEY_EU encrypts project
# DSNs at rest and MIDPLANE_TOKEN_PEPPER_EU_V1 backs machine-token verification —
# changing either bricks every stored credential and token.
MIDPLANE_KMS_MODE=env
# Generate: openssl rand -hex 32
MIDPLANE_KMS_DEV_KEY_EU=
# Generate: openssl rand -base64 32
MIDPLANE_TOKEN_PEPPER_EU_V1=

# The engine. Self-host exec's the compiled `midplane server` binary as a
# subprocess per connection (no Docker daemon, no image pull — see SELF_HOST.md).
# The self-host image ships it on PATH as `midplane`; override the path only if
# you built the binary yourself (`bun run build:engine-binary`):
# MIDPLANE_ENGINE_BIN=/path/to/midplane
#
# The audit pipeline's internal bearer is auto-provisioned at boot (the engine
# is loopback-only, so the token never leaves the box). Set it explicitly only
# if you want a fixed value:
# INDEXER_TOKEN=

# Postgres password / host port for the bundled compose (optional; defaults
# shown). Read via `--env-file .env.self-host` (which `bin/self-host` passes),
# so uncommenting them here actually takes effect. If host port 5432 is already
# taken, set POSTGRES_PORT to a free port — the compose mapping honors it.
# POSTGRES_PASSWORD=midplane
# POSTGRES_PORT=5432
