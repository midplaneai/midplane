#!/bin/sh
# Midplane self-host bootstrap — one command from a fresh clone to a running
# dashboard, Docker the only prerequisite (no Bun, no manual migrations, no
# hand-generated secrets).
#
#   ./bin/self-host up        # generate secrets + bring the stack up
#   ./bin/self-host down      # stop the stack (data volume kept)
#   ./bin/self-host upgrade   # pull newer images + restart
#
# Secrets are generated ONCE into .env.self-host and reused on every boot.
# MIDPLANE_KMS_DEV_KEY_EU encrypts project DSNs at rest and
# MIDPLANE_TOKEN_PEPPER_EU_V1 backs machine-token verification — regenerating
# either bricks every stored credential and token, so this script never
# regenerates a value that is already set.
set -eu

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

ENV_FILE=".env.self-host"
EXAMPLE=".env.self-host.example"
COMPOSE_FILE="docker-compose.self-host.yml"

# `docker compose` (v2) is the interface; `--env-file` makes the file drive both
# ${VAR} interpolation (POSTGRES_PORT, the secrets) and, via the compose file's
# `environment:` blocks, the container env. Raw `docker compose` without it reads
# `.env`, not `.env.self-host` — every doc/command must carry this flag.
compose() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "error: docker is not installed or not on PATH." >&2
    echo "Install Docker Desktop (macOS/Windows) or Docker Engine (Linux) and retry." >&2
    exit 1
  fi
  if ! docker compose version >/dev/null 2>&1; then
    echo "error: 'docker compose' (v2) is unavailable. Update Docker to a release" >&2
    echo "that bundles Compose v2 (Docker Desktop, or the docker-compose-plugin)." >&2
    exit 1
  fi
}

# 32 bytes of randomness. Prefer openssl; fall back to /dev/urandom so the script
# works on a stock box without openssl.
rand_b64() { openssl rand -base64 32 2>/dev/null || head -c 32 /dev/urandom | base64 | tr -d '\n'; }
rand_hex() { openssl rand -hex 32 2>/dev/null || od -An -tx1 -N 32 /dev/urandom | tr -d ' \n'; }

# Fill an EMPTY `KEY=` line in $ENV_FILE with a value. No-op if the key already
# has a value (never clobber a persisted secret). awk builds the replacement line
# so base64 padding (`=`, `+`, `/`) survives untouched — no sed delimiter games.
fill_if_empty() {
  key="$1"
  val="$2"
  if grep -Fxq "${key}=" "$ENV_FILE"; then
    awk -v k="$key" -v v="$val" '$0 == k"=" { print k"=" v; next } { print }' \
      "$ENV_FILE" > "$ENV_FILE.tmp" && mv "$ENV_FILE.tmp" "$ENV_FILE"
    echo "  generated $key"
  fi
}

# Set KEY=VALUE in $ENV_FILE, whether the key ships commented (`# KEY=...`),
# empty (`KEY=`), or already set — uncomments/replaces the FIRST matching line
# in place, or appends if the key is absent. awk builds the line so URL and
# base64 characters survive verbatim (no sed delimiter games), and the narrow
# `KEY=` anchor never disturbs the base64 secret lines.
set_env_key() {
  key="$1"
  val="$2"
  if grep -Eq "^[[:space:]]*#?[[:space:]]*${key}=" "$ENV_FILE"; then
    awk -v k="$key" -v v="$val" '
      !seen && $0 ~ ("^[[:space:]]*#?[[:space:]]*" k "=") {
        print k "=" v; seen = 1; next
      }
      { print }
    ' "$ENV_FILE" > "$ENV_FILE.tmp" && mv "$ENV_FILE.tmp" "$ENV_FILE"
  else
    printf '%s=%s\n' "$key" "$val" >> "$ENV_FILE"
  fi
}

# The explicitly-set host port: an uncommented, non-empty WEB_PORT= line in
# $ENV_FILE, or empty if it's unset (still commented — the fresh-file default).
explicit_web_port() {
  grep -E '^[[:space:]]*WEB_PORT=' "$ENV_FILE" 2>/dev/null | tail -n1 \
    | cut -d= -f2- | tr -d '[:space:]'
}

# The host port the dashboard is published on. Mirrors the compose default of
# ${WEB_PORT:-3000}: an explicit WEB_PORT wins, otherwise 3000. Read after `up`
# so the printed URL matches an auto-selected or remapped port.
web_port() {
  val=$(explicit_web_port)
  [ -n "$val" ] && echo "$val" || echo 3000
}

# True when the user (or a previous auto-select) pinned WEB_PORT. A pinned port
# is honored exactly and never auto-moved — moving it would invalidate live
# sessions and the MCP URLs agents already hold.
web_port_is_set() {
  [ -n "$(explicit_web_port)" ]
}

# The configured BETTER_AUTH_URL (drives cookie domain, OAuth callbacks, and the
# MCP URL shown to agents — so it must always name the published host port).
better_auth_url() {
  grep -E '^[[:space:]]*BETTER_AUTH_URL=' "$ENV_FILE" 2>/dev/null | tail -n1 \
    | cut -d= -f2- | tr -d '[:space:]'
}

# True if compose's output names a host-port bind conflict — the ONLY retryable
# failure. Matched case-insensitively against the variants Docker/Compose emit
# across platforms (Linux userland-proxy, macOS/Windows Docker Desktop).
is_port_conflict() {
  grep -Eiq 'address already in use|port is already allocated|ports are not available'
}

# Actionable message for a bind conflict we won't auto-resolve. Names BOTH knobs
# because they must move together: a port that disagrees with BETTER_AUTH_URL
# boots but hands agents a dead MCP URL and breaks cookies. $1 is the subject
# clause, e.g. "port 3000 (WEB_PORT) is" or "ports 3000-3010 (WEB_PORT) are".
port_conflict_message() {
  echo "error: $1 already in use. Set WEB_PORT and BETTER_AUTH_URL in $ENV_FILE to a" >&2
  echo "       free port (they must match), then re-run ./bin/self-host up." >&2
  echo "       (Driving \`docker compose … up\` yourself? Choose a free port directly.)" >&2
}

# Run `compose up -d --wait`, optionally overriding WEB_PORT / BETTER_AUTH_URL
# for this attempt (pass "" to leave either at its env-file value). Streams
# compose's own output live AND captures it so a failure can be classified. The
# real bind is the free-port test — a conflict fails fast at container start,
# before the healthcheck, so probing is cheap. Sets:
#   CU_RC  — compose's real exit code (captured before the tee pipeline)
#   CU_ERR — the streamed output, for is_port_conflict
compose_up_wait() {
  _port="$1"
  _auth="$2"
  _errfile=$(mktemp)
  _rcfile=$(mktemp)
  # Left side of the pipe is a subshell: `set +e` and the exports stay local
  # (WEB_PORT/BETTER_AUTH_URL never leak to the parent), and echoing $? right
  # after compose captures its real exit — the pipeline's own status is tee's.
  {
    set +e
    [ -n "$_port" ] && export WEB_PORT="$_port"
    [ -n "$_auth" ] && export BETTER_AUTH_URL="$_auth"
    compose up -d --wait 2>&1 1>/dev/null
    echo $? > "$_rcfile"
  } | tee "$_errfile" >&2
  CU_RC=$(cat "$_rcfile" 2>/dev/null || echo 1)
  CU_ERR=$(cat "$_errfile" 2>/dev/null || echo)
  rm -f "$_errfile" "$_rcfile"
}

# WEB_PORT is pinned — honor it exactly. On a bind conflict, refuse to move it
# silently (that would strand existing sessions + agent MCP configs): surface
# the actionable message and exit non-zero. Any other failure surfaces as-is.
explicit_up() {
  echo "starting the self-host stack (port $(web_port))…"
  compose_up_wait "" ""
  if [ "$CU_RC" -eq 0 ]; then
    return 0
  fi
  if printf '%s\n' "$CU_ERR" | is_port_conflict; then
    port_conflict_message "port $(web_port) (WEB_PORT) is"
    exit 1
  fi
  echo "error: \`compose up\` failed (exit $CU_RC); see the output above." >&2
  exit "$CU_RC"
}

# WEB_PORT is unset (fresh-file default) — auto-select. Prefer 3000, then ascend
# to a small cap so the conventional port keeps working in the common case and
# no doc that says "localhost:3000" is made wrong by a random high port. Persist
# the winner (WEB_PORT, plus BETTER_AUTH_URL when we still own its default) so
# later boots read the same port and stay stable.
autoselect_up() {
  cap=3010
  cur_auth=$(better_auth_url)
  # Only rewrite BETTER_AUTH_URL if it's still the shipped default; a customized
  # value (proxy/hostname) is the user's — leave it, and warn instead.
  rewrite_auth=0
  case "$cur_auth" in
    http://localhost:3000 | "") rewrite_auth=1 ;;
  esac

  candidate=3000
  while [ "$candidate" -le "$cap" ]; do
    if [ "$rewrite_auth" -eq 1 ]; then
      auth_env="http://localhost:$candidate"
    else
      auth_env="$cur_auth"
    fi
    echo "starting the self-host stack (trying port $candidate)…"
    compose_up_wait "$candidate" "$auth_env"
    if [ "$CU_RC" -eq 0 ]; then
      set_env_key WEB_PORT "$candidate"
      if [ "$rewrite_auth" -eq 1 ]; then
        set_env_key BETTER_AUTH_URL "http://localhost:$candidate"
        echo "  persisted WEB_PORT=$candidate + BETTER_AUTH_URL=http://localhost:$candidate to $ENV_FILE"
      else
        echo "  persisted WEB_PORT=$candidate to $ENV_FILE"
        echo "  note: BETTER_AUTH_URL is customized ($cur_auth) and was left as-is —" >&2
        echo "        confirm it resolves to the published host port $candidate." >&2
      fi
      return 0
    fi
    if printf '%s\n' "$CU_ERR" | is_port_conflict; then
      echo "  port $candidate is in use; trying $((candidate + 1))…"
      candidate=$((candidate + 1))
      continue
    fi
    echo "error: \`compose up\` failed (exit $CU_RC); see the output above." >&2
    exit "$CU_RC"
  done
  port_conflict_message "ports 3000-$cap (WEB_PORT) are"
  exit 1
}

ensure_env() {
  if [ ! -f "$ENV_FILE" ]; then
    if [ ! -f "$EXAMPLE" ]; then
      echo "error: $EXAMPLE not found — run this from a Midplane checkout." >&2
      exit 1
    fi
    cp "$EXAMPLE" "$ENV_FILE"
    echo "created $ENV_FILE from $EXAMPLE"
  fi
  echo "filling any missing secrets in $ENV_FILE (existing values kept):"
  fill_if_empty "BETTER_AUTH_SECRET" "$(rand_b64)"
  fill_if_empty "MIDPLANE_KMS_DEV_KEY_EU" "$(rand_hex)"
  fill_if_empty "MIDPLANE_TOKEN_PEPPER_EU_V1" "$(rand_b64)"
}

cmd_up() {
  require_docker
  ensure_env
  # Prefer the published image (fast); fall back to a local build for forks/dev
  # or before the image is published. A pull miss is non-fatal — `up` then builds
  # from the compose `build:` block.
  compose pull 2>/dev/null || echo "  (image pull skipped — building from source)"
  # Pinned WEB_PORT → honor it (fail loudly on conflict). Unset → auto-select a
  # free port and persist it. Both keep BETTER_AUTH_URL aligned with the port.
  if web_port_is_set; then
    explicit_up
  else
    autoselect_up
  fi
  echo
  echo "Midplane self-host is up → http://localhost:$(web_port)"
  echo "The first email + password signup becomes the owner."
}

cmd_down() {
  require_docker
  compose down
}

cmd_upgrade() {
  require_docker
  ensure_env
  compose pull
  compose up -d --wait
  echo "upgraded."
}

case "${1:-}" in
  up) cmd_up ;;
  down) cmd_down ;;
  upgrade) cmd_upgrade ;;
  *)
    echo "usage: ./bin/self-host <up|down|upgrade>" >&2
    exit 1
    ;;
esac
