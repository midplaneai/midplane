# Midplane self-host configuration.
# Copy to `.env` (gitignored) and fill in your values.

# Required. Your Postgres connection string.
# Best practice: a scoped role with least privilege — the agent's role should
# be exactly as broad as you want the agent to be.
DATABASE_URL=postgres://your-readonly-agent:pass@your-db:5432/your-db

# Optional. HTTP port for the MCP endpoint. compose.yaml reads this for the
# host:container port mapping AND the /health probe — set it once here and
# both the publish rule and the healthcheck follow.
# PORT=8080

# Optional. Path to the SQLite audit log inside the container.
# Must stay inside /data if you want compose.yaml's named volume to persist
# it across restarts. To put it elsewhere, edit the volume mount in
# compose.yaml so the parent directory matches.
# DB_PATH=/data/audit.db

# Optional. Tenant ID for the tenant_scope policy rule.
# See docs/policy-rules.md for the matching YAML configuration.
# MIDPLANE_TENANT_ID=

# Optional. Path to a YAML policy override file (mount it into the container).
# MIDPLANE_POLICY_FILE=/etc/midplane/policy.yaml

# Optional. MCP transport: "stdio" or "http". Defaults to http for the image.
# MIDPLANE_TRANSPORT=http

# Optional. Bearer token for the audit pull endpoints. Unset → endpoints 404.
# Set this only if you're shipping the audit log to an external collector
# (SIEM, warehouse, etc.). See docs/self-host.md.
# INDEXER_TOKEN=
