# =============================================================================
# Midplane Cloud — local dev environment.
# Copy to .env.local. Never commit secrets. Bootstrap is single-region (eu).
# =============================================================================

# --- Postgres (one Neon project per region) ---------------------------------
# Local dev typically uses the EU dev branch only; production sets both via
# Fly secrets and the cross-region one is intentionally unset on each
# regional app (env-var locality — `getDb('us')` from the EU app throws if
# DATABASE_URL_US isn't set, which is what we want).
DATABASE_URL_EU=postgres://...eu-central-1.aws.neon.tech/midplane_dev?sslmode=require
DATABASE_URL_US=

# Which region this process represents. Each regional Fly app sets this to
# "eu" or "us"; tests + local dev default to "eu".
MIDPLANE_REGION=eu

# Read-path region enforcement. true = middleware 302s cross-region requests
# (production default). false = log-only shadow mode used for the first
# 24h after deploy so any backfill gap surfaces as logs without breaking
# traffic. Signup writes always enforce regardless of this flag.
MIDDLEWARE_ENFORCE=true

# HMAC key for the signed region cookie (lib/region-routing). Routes an authed
# user from the apex to their regional subdomain with no DB read. Must be the
# SAME across the apex + both regional apps so any can verify; min 32 chars,
# `openssl rand -base64 32`. Distinct from BETTER_AUTH_SECRET (region is
# decoupled from auth).
MIDPLANE_REGION_COOKIE_SECRET=

# --- Better Auth ------------------------------------------------------------
# Signs/encrypts sessions. Min 32 chars, high entropy: `openssl rand -base64 32`.
# Regional: each regional app reads its OWN secret (sessions are region-resident).
BETTER_AUTH_SECRET=
# Base URL of THIS app. Per-region host in prod (e.g. https://eu.app.midplane.ai);
# localhost in dev. Drives cookie domain + callback URLs, AND is the OAuth 2.1
# issuer the MCP plugin advertises in its discovery metadata (the agent OAuth
# flow). Required — boot fails fast if unset.
BETTER_AUTH_URL=http://localhost:3000

# Founder / internal plan override is NOT an env var — it's the
# customers.plan_override column (NULL = resolve normally). See
# apps/web/src/lib/plan.ts.

# --- Google sign-in (optional) ----------------------------------------------
# "Continue with Google" on sign-in / sign-up. Both vars must be set or the
# provider stays OFF (no button rendered) — keyless dev and self-host get no
# Google unless they opt in here. Create an OAuth client ID (Web application) in
# the Google Cloud Console and register the callback per regional origin:
#   <BETTER_AUTH_URL>/api/auth/callback/google
# e.g. http://localhost:3000/api/auth/callback/google (dev),
#      https://eu.app.midplane.ai/api/auth/callback/google,
#      https://us.app.midplane.ai/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- KMS (dev mode) ---------------------------------------------------------
# "env" = AES-256-GCM with a local symmetric key (bootstrap default).
# "kms" = AWS KMS (prod). Reads the per-region CMK ARN from
#         MIDPLANE_KMS_KEY_<REGION> and the wrapped token pepper from
#         MIDPLANE_TOKEN_PEPPER_CT_<REGION>_V1.
MIDPLANE_KMS_MODE=env
# 32-byte hex (run: openssl rand -hex 32). Different keys per region in prod.
MIDPLANE_KMS_DEV_KEY_EU=
MIDPLANE_KMS_DEV_KEY_US=

# --- Token pepper -----------------------------------------------------------
# HMAC key used to hash mcp_tokens.token_hash at rest. One pepper per region.
#
# env mode: base64 of 32 random bytes (run: openssl rand -base64 32).
MIDPLANE_TOKEN_PEPPER_EU_V1=
MIDPLANE_TOKEN_PEPPER_US_V1=
# kms mode: base64 of the CiphertextBlob from `kms:Encrypt` under the same CMK
# referenced by MIDPLANE_KMS_KEY_<REGION>, with EncryptionContext
# `region=<region>,purpose=token-pepper`. Mint with:
#   scripts/encrypt-token-pepper.sh eu <CMK ARN>
MIDPLANE_TOKEN_PEPPER_CT_EU_V1=
MIDPLANE_TOKEN_PEPPER_CT_US_V1=

# --- Masking salt master ----------------------------------------------------
# Per-deployment master secret for column masking. The control plane derives a
# per-project salt = HMAC(MIDPLANE_MASK_SALT_MASTER, projectId) and injects it
# into the engine; it keys the DETERMINISTIC transforms (consistent-hash,
# pseudonymize) so masked values aren't correlatable. 32+ bytes
# (run: openssl rand -hex 32). Keep it STABLE — rotating re-randomizes every
# deterministic output (treat like a pepper). One key, both regions.
#
# Optional: only required if any project declares column_masks. If unset, the
# engine fail-closes (refuses to spawn a masked project) and the masking UI
# disables the mask controls and says so. Leave blank to run without masking.
MIDPLANE_MASK_SALT_MASTER=

# --- Fly (regional MCP runtime apps) ----------------------------------------
# FLY_API_TOKEN is needed to spawn machines from the router. Bootstrap can
# stub this; only required once router actually proxies traffic to Fly.
FLY_API_TOKEN=
FLY_APP_EU=midplane-eu
FLY_APP_US=midplane-us
# Fly DC airport code each jurisdiction app lives in. Lets us route the EU
# jurisdiction to ams instead of fra later without renaming anything else.
FLY_REGION_EU=fra
FLY_REGION_US=iad

# --- Public URL roots (used to mint MCP endpoint URLs) ----------------------
# Dev defaults to localhost:3000 — the web app's proxyMcp serves /mcp/<token>
# in every environment. Prod values are e.g. eu.midplane.ai / us.midplane.ai.
MIDPLANE_PUBLIC_HOST_EU=localhost:3000
MIDPLANE_PUBLIC_HOST_US=localhost:3000

# --- OSS engine image pin ---------------------------------------------------
# The image the router spawns. Cloud is pinned to the locked OSS version.
MIDPLANE_OSS_IMAGE=midplane/midplane:0.14.0

# Set to "1" to pull the engine from GHCR (ghcr.io/midplaneai/midplane) instead
# of Docker Hub on the Fly spawn path. Fly pulls Docker Hub images through its
# own pull-through mirror (docker-hub-mirror.fly.io); when that mirror runs out
# of disk it 500s on manifest writes and 502s cold spawns. GHCR is pulled
# directly and sidesteps it. Requires the GHCR image to be published + Public
# first (engine-publish.yml). When on, this rewrites the engine ref — including a
# staged MIDPLANE_OSS_IMAGE=midplane/midplane:<tag> — to the GHCR mirror at the
# same tag; only a custom non-engine image is left untouched. Unset/"0" = Docker
# Hub (default).
# MIDPLANE_ENGINE_USE_GHCR=1

# --- Staff allowlist --------------------------------------------------------
# Comma-separated user IDs allowed to call /admin/customer/:id/region.
# Midplane staff are not customer org members, so org-role checks don't
# apply — user-level allowlist is correct. Unset = no staff identity.
MIDPLANE_STAFF_USER_IDS=

# --- PostHog (server-side analytics) ----------------------------------------
# Authenticated cloud-user events (signup, project + token lifecycle) go
# directly from the Next.js server to PostHog via posthog-node. Unset = no
# events emitted (dev + CI default). Set both on each regional Fly web app
# to turn on capture in production.
#
# Distinct from the OSS engine telemetry proxy at infra/telemetry-proxy
# (t.midplane.ai), which forwards anonymized install_id events. Same
# PostHog project, two sources.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- E2E -------------------------------------------------------------------
# The live E2E suites establish sessions via the Better Auth sign-up API
# in-test (see e2e/_auth-helpers.ts) — no auth provider keys needed. They reuse
# BETTER_AUTH_SECRET + MIDPLANE_REGION_COOKIE_SECRET + DATABASE_URL_<REGION>
# above, and run under E2E_LIVE=1.

# --- Ping guard (SSRF) --------------------------------------------------------
# Host vetting for every server-side DSN reachability test (new-project
# form, add-database form, saved-db test). "on" rejects DSNs whose host
# resolves to loopback / private / link-local / metadata space and pins the
# dial to the vetted IP. Default: on in production, off elsewhere — local
# dev legitimately pings postgres://localhost. Set explicitly to override.
PING_GUARD=

# --- Stripe billing (cloud-only) --------------------------------------------
# Hosted Checkout + Customer Portal via the @better-auth/stripe plugin. ALL FOUR
# vars or NONE: unset = billing off (the app boots fine and /billing shows
# "talk to us"); a PARTIAL set fails assertBootEnv at boot. Never set in
# self-host — the plugin isn't loaded there and no Stripe key is needed to boot.
#
# Use TEST keys. Create the products/prices + get the price IDs with:
#   STRIPE_SECRET_KEY=sk_test_... bun run scripts/stripe-setup.ts
# For local webhook delivery, run:
#   stripe listen --forward-to localhost:3000/api/auth/stripe/webhook
# and paste the printed whsec_... into STRIPE_WEBHOOK_SECRET.
#
# In prod each regional web app sets its OWN STRIPE_WEBHOOK_SECRET (one Stripe
# webhook endpoint per regional host); the same price IDs are shared.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# --- Resend transactional email (cloud-only) --------------------------------
# Delivers transactional email via Resend (https://resend.com) — workspace
# invitations and password resets, with replies routed to the support mailbox
# (lib/support.ts). BOTH vars or NONE: unset = email off (the app boots fine;
# invites fall back to the copyable link surfaced in /settings and password
# reset isn't offered); both set = transactional email is on.
# Never set in self-host — it ships no SMTP and the link is shared out-of-band.
# EMAIL_FROM must be a verified Resend sender, e.g. "Midplane <invites@midplane.ai>".
RESEND_API_KEY=
EMAIL_FROM=

# --- Loops lifecycle email (cloud-only) --------------------------------------
# Fires lifecycle events to Loops (https://loops.so) — today: the `signup`
# event that triggers the founder welcome email (the template lives in Loops).
# Unset = no events fire (the app boots fine). Never set in self-host.
# COMPLIANCE GATE: leave unset until the privacy policy (midplane.ai/privacy)
# lists Loops as a processor.
LOOPS_API_KEY=

# --- Sample database (cloud-only, optional) ----------------------------------
# DSN of the hosted read-only demo Postgres behind the new-project form's
# "Try with our sample database" link — the escape hatch for evaluators with
# no reachable Postgres of their own. Unset = the link is hidden (the kill
# switch if the shared instance is abused). The DSN renders in the dashboard,
# so it is effectively public by design: every abuse guardrail lives on the
# DB role, not on secrecy. Provisioning: scripts/sample-db/README.md.
MIDPLANE_SAMPLE_DSN=

# --- Enterprise Edition (ee/) -----------------------------------------------
# MIDPLANE_EE=1 activates the commercial Enterprise features under apps/web/src/
# ee/ — today: SSO/SAML (the Better Auth sso plugin). Unset (the default) = the
# ee plugin never loads, the SSO surface stays dark, and core runs uncapped MIT.
# The per-org gate is still the plan (hasEntitlement("sso") = this flag AND the
# Team plan), so set this on the cloud build; never in self-host (keyless, ee
# off by design). The signed-license verifier is deferred (design doc D3) — this
# is a plain build switch for now.
# MIDPLANE_EE=1

# =============================================================================
# SELF-HOST (single-tenant) — MIDPLANE_SELF_HOST=1
# =============================================================================
# Flip this block ON to run the control plane standalone against ONE Postgres
# and a local engine: keyless, uncapped, single-owner, no region routing, no
# cloud vendors. When MIDPLANE_SELF_HOST is unset (the default), this entire
# block is ignored and the multi-tenant CLOUD config above applies unchanged.
#
# Self-host pins its region internally to 'eu' (SELF_HOST_REGION) — getDb
# ignores the region argument and bootRegion() returns it, so you do NOT set
# MIDPLANE_REGION. The audit pipeline still stamps/filters that fixed region.
#
# MIDPLANE_SELF_HOST=1
#
# Single Postgres (replaces DATABASE_URL_EU / DATABASE_URL_US):
# DATABASE_URL=postgres://midplane:midplane@localhost:5432/midplane?sslmode=disable
#
# Session signing — same as cloud. openssl rand -base64 32:
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000
#
# Credential encryption at rest — reuse env-mode (no AWS in self-host). The
# _EU suffix is an internal artifact of the region pin above; these are local
# AES key material, not a regional choice:
# MIDPLANE_KMS_MODE=env
# MIDPLANE_KMS_DEV_KEY_EU=        # openssl rand -hex 32
# MIDPLANE_TOKEN_PEPPER_EU_V1=    # openssl rand -base64 32
#
# NOT set in self-host (cloud-only): DATABASE_URL_EU/US, MIDPLANE_REGION,
# MIDPLANE_REGION_COOKIE_SECRET, MIDDLEWARE_ENFORCE, FLY_*, INDEXER_TOKEN,
# MIDPLANE_KMS_KEY_*, MIDPLANE_TOKEN_PEPPER_CT_*, STRIPE_* (self-host is
# uncapped and never bills — the stripe plugin isn't loaded), RESEND_API_KEY /
# EMAIL_FROM (no SMTP — teammate invites are shared as a link), LOOPS_API_KEY
# (no lifecycle email), MIDPLANE_SAMPLE_DSN (the hosted demo DB is a cloud
# funnel surface), MIDPLANE_EE (keyless — Enterprise/SSO is off in self-host
# by design).
