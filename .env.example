# =============================================================================
# Midplane Cloud — local dev environment.
# Copy to .env.local. Never commit secrets. Bootstrap is single-region (eu).
# =============================================================================

# --- Postgres (one Neon project per region) ---------------------------------
# Local dev typically uses the EU dev branch only; production sets both via
# Fly secrets and the cross-region one is intentionally unset on each
# regional app (env-var locality — `getDb('us')` from the EU app throws if
# DATABASE_URL_US isn't set, which is what we want).
DATABASE_URL_EU=postgres://...eu-central-1.aws.neon.tech/midplane_dev?sslmode=require
DATABASE_URL_US=

# Which region this process represents. Each regional Fly app sets this to
# "eu" or "us"; tests + local dev default to "eu".
MIDPLANE_REGION=eu

# Read-path region enforcement. true = middleware 302s cross-region requests
# (production default). false = log-only shadow mode used for the first
# 24h after deploy so any backfill gap surfaces as logs without breaking
# traffic. Signup writes always enforce regardless of this flag.
MIDDLEWARE_ENFORCE=true

# --- Clerk (dev keys from Clerk dashboard) ----------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/signup/region

# --- KMS (dev mode) ---------------------------------------------------------
# "env" = AES-256-GCM with a local symmetric key (bootstrap default).
# "kms" = AWS KMS (prod; not wired in bootstrap).
MIDPLANE_KMS_MODE=env
# 32-byte hex (run: openssl rand -hex 32). Different keys per region in prod.
MIDPLANE_KMS_DEV_KEY_EU=
MIDPLANE_KMS_DEV_KEY_US=

# --- Fly (regional MCP runtime apps) ----------------------------------------
# FLY_API_TOKEN is needed to spawn machines from the router. Bootstrap can
# stub this; only required once router actually proxies traffic to Fly.
FLY_API_TOKEN=
FLY_APP_EU=midplane-eu
FLY_APP_US=midplane-us
# Fly DC airport code each jurisdiction app lives in. Lets us route the EU
# jurisdiction to ams instead of fra later without renaming anything else.
FLY_REGION_EU=fra
FLY_REGION_US=iad

# --- Public URL roots (used to mint MCP endpoint URLs) ----------------------
# Dev defaults to localhost:3000 — Next.js serves /mcp/<token> directly until
# the Fly proxy lands. Prod values are e.g. eu.midplane.com / us.midplane.com.
MIDPLANE_PUBLIC_HOST_EU=localhost:3000
MIDPLANE_PUBLIC_HOST_US=localhost:3000

# --- OSS engine image pin ---------------------------------------------------
# The image the router spawns. Cloud is pinned to the locked OSS version.
MIDPLANE_OSS_IMAGE=midplane/midplane:0.6.0

# --- Staff allowlist --------------------------------------------------------
# Comma-separated Clerk user IDs allowed to call /admin/customer/:id/region.
# Midplane staff are not customer org members, so org-role checks don't
# apply — user-level allowlist is correct. Unset = no staff identity.
MIDPLANE_STAFF_USER_IDS=

# --- E2E (Clerk testing token) ----------------------------------------------
# CLERK_PUBLISHABLE_KEY + CLERK_SECRET_KEY drive @clerk/testing/playwright.
# Falls back to NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY if unset, so by default no
# extra config is needed beyond the dev keys above. Keep these scoped to the
# Clerk DEVELOPMENT instance — never plumb production keys into tests.
CLERK_PUBLISHABLE_KEY=
# Optional. The signup E2E mints a fresh testing token at suite start via
# clerkSetup(); only set this if you need to pin a specific token.
CLERK_TESTING_TOKEN=
